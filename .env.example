# --- Core router config ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

# Embedding / semantic cache
EMBED_MODEL=nomic-embed-text
SEMANTIC_THRESHOLD=0.92
SEMANTIC_MAX_AGE_SECONDS=86400
CACHE_TTL=3600

# Ollama behaviour
OLLAMA_TIMEOUT=120
OLLAMA_MAX_CONCURRENT=6
OLLAMA_RETRIES=3

# Router security
ROUTER_API_KEY=a3c7853245277afe3151442ace9ec242ce07275ef257a6b2ca8f4ac79d9fda67
RATE_LIMIT_PER_MINUTE=120

# Gemini fallback (Phase 2) — FIXED
GEMINI_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY=AIzaSyB6lKjiqYeqWp4fMFnrNVLKtHQ_nUDrZFY
GEMINI_MODEL=gemini-2.5-flash

#Subnet CIDRs that can bypass API key authentication (comma-separated).
AUTH_BYPASS_CIDRS=172.17.0.0/16,172.17.0.1